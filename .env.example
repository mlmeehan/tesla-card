# Tesla card E2E (Playwright) — copy to .env and adjust if needed.
# The suite is offline/hermetic: it builds the card and serves the demo harness
# locally, so no real Home Assistant instance or network backend is required.

# Where the demo harness is served (Playwright baseURL). Override only to point at
# an already-running static server; otherwise the config's webServer handles it.
BASE_URL=http://127.0.0.1:4173

# Free-form environment label surfaced in logs/reports.
TEST_ENV=local

# Unused by this offline card harness — kept for template parity and any future
# live-HA API-level tests. Leave blank.
API_URL=
