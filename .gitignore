assets/

# Transient probes planted by the co-located gate tests (import-allowlist,
# no-network-egress, no-bare-hass-states, no-cycle) to exercise the real gates
# (normally removed in a finally; this guards against a hard-killed run leaving one
# behind).
src/__import_allowlist_probe__.ts
src/__no_network_egress_probe__.ts
src/__no_bare_hass_probe__.ts
src/__no_cycle_probe_a__.ts
src/__no_cycle_probe_b__.ts

