{
  "name": "tesla-card",
  "version": "0.2.0",
  "description": "A Tesla-app-inspired Lovelace card for Home Assistant (Tesla Fleet / Teslemetry).",
  "type": "module",
  "main": "dist/tesla-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc -p tests/tsconfig.json",
    "lint": "node scripts/lint/no-bare-hass-states.mjs && node scripts/lint/no-cycle.mjs && node scripts/lint/trade-dress-denylist.mjs && node scripts/lint/import-allowlist.mjs && node scripts/lint/no-network-egress.mjs && node scripts/lint/version-sync.mjs",
    "demo": "npm run build && echo 'Open demo/index.html in a browser'",
    "serve:demo": "http-server . -a 127.0.0.1 -p 4173 -c-1 -s",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:visual": "VISUAL=1 playwright test --grep @visual",
    "test:e2e:burn-in": "bash scripts/burn-in.sh",
    "ci:local": "bash scripts/ci-local.sh"
  },
  "keywords": [
    "home-assistant",
    "homeassistant",
    "lovelace",
    "custom-card",
    "tesla",
    "ev",
    "hacs"
  ],
  "author": "Mike Meehan <mike@mmeehan.dev>",
  "license": "MIT",
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^20.17.0",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.1",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vitest": "4.1.8"
  }
}
