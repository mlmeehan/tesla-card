{
  "name": "tesla-card",
  "version": "0.1.0",
  "description": "A Tesla-app-inspired Lovelace card for Home Assistant (Tesla Fleet / Teslemetry).",
  "type": "module",
  "main": "dist/tesla-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "demo": "npm run build && echo 'Open demo/index.html in a browser'"
  },
  "keywords": [
    "home-assistant",
    "homeassistant",
    "lovelace",
    "custom-card",
    "tesla",
    "ev",
    "hacs"
  ],
  "author": "Mike Meehan <mike@mmeehan.dev>",
  "license": "MIT",
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  }
}
